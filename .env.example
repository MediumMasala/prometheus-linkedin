# ===========================================
# Prometheus LinkedIn Campaign Analyzer
# Environment Variables
# ===========================================

# Server Configuration
PORT=3001
NODE_ENV=production

# LinkedIn OAuth (required)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_AD_ACCOUNT_ID=your_ad_account_id
LINKEDIN_REDIRECT_URI=https://your-app.onrender.com/callback

# LinkedIn Access Token (for production)
# Get this from http://localhost:3001/api/linkedin/token-info after local OAuth
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# OpenAI API (required for AI batching)
OPENAI_API_KEY=sk-proj-your-openai-key

# Authentication (required for production)
AUTH_USERNAME=admin
AUTH_PASSWORD=your_secure_password
JWT_SECRET=your-very-long-random-secret-key-change-this

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
COST_ALERT_THRESHOLD=500

# Development Only
# AUTH_DISABLED=true
