# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_AD_ACCOUNT_ID=your_ad_account_id
LINKEDIN_REDIRECT_URI=http://localhost:5173/callback

# Gemini API (for AI batching and matching)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# Server
PORT=3001

# Mastra (optional)
MASTRA_LOG_LEVEL=info

# Slack Alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
COST_ALERT_THRESHOLD=350

# ============================================================================
# CONTENT MARKETING PIPELINE (Tal Video Creation)
# All CM_* variables are isolated from the analytics pipeline
# ============================================================================

# Required API Keys
CM_OPENAI_API_KEY=your_openai_api_key
CM_GOOGLE_AI_API_KEY=your_google_ai_api_key
CM_ELEVENLABS_API_KEY=your_elevenlabs_api_key
CM_REPLICATE_API_KEY=your_replicate_api_key

# Optional Configuration (defaults shown)
CM_OUTPUT_DIR=output/content-marketing
CM_DEFAULT_VOICE_ID=nPczCjzI2devNBz1zQrb
CM_VIDEO_RESOLUTION=1080x1920
CM_MAX_SCENE_COUNT=20
CM_TTS_MODEL_ID=eleven_multilingual_v2
